                    right -> {
                        mut span = alloc_span(left^.span^.start_line, left^.span^.start_col, right^.span^.end_line, right^.span^.end_col)
                        
                        mut bin_expr = alloc BinaryExpr()
                        bin_expr^.left = left
                        bin_expr^.op = op
                        bin_expr^.right = right
                        
