                        left = expr
                    }
                }
            }
            mut ret: ?^Spanned(Expression) = None
            ret = left
            return ret
        }
    }
}
fn parse_bitwise_xor_expr(mut p: ^Parser) -> ?^Spanned(Expression) {
    mut left_opt = parse_bitwise_and_expr(p)
    when left_opt {
        None -> {
            mut ret: ?^Spanned(Expression) = None
            return ret
        }
        l -> {
            mut left = l
            while check_token(p^.current_token^.kind, "BitXor") {
