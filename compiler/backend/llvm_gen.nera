            i64_ty^ = LLVMType.I64
            mut pi64_ty = alloc LLVMType()
            pi64_ty^ = LLVMType.Pointer(i64_ty)
            
            let casted_tag_ptr = ir_builder_build_bitcast(gen^.builder, struct_ptr, pi64_ty)
            ir_builder_build_store(gen^.builder, tag_val, casted_tag_ptr, 8)
            
            mut i = 0
            while i < args^.length {
                let arg_op = list_get(args, i)
                mut arg_op_ptr = alloc IROperand()
                arg_op_ptr^ = arg_op
                let arg_val = llvm_generator_operand_to_value(gen, arg_op_ptr)
                
                let current_offset = 8 + (i * 8)
                mut off_val = alloc LLVMValue()
                off_val^ = LLVMValue.ConstI64(current_offset)
                mut idx_list = new_list(1, dummy_lv)
                list_push(idx_list, off_val^)
                
                let field_ptr = ir_builder_build_gep(gen^.builder, i8_inner, struct_ptr, idx_list)
                
                let val_ty = llvm_value_get_type(arg_val)
                mut pval_ty = alloc LLVMType()
                pval_ty^ = LLVMType.Pointer(val_ty)
                
                let casted_field_ptr = ir_builder_build_bitcast(gen^.builder, field_ptr, pval_ty)
                ir_builder_build_store(gen^.builder, arg_val, casted_field_ptr, 8)
                
                i = i + 1
            }
            
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = struct_ptr
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
