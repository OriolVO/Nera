        LoadStringChar(dest, str_ptr, idx_op) -> {
            let str_val = llvm_generator_operand_to_value(gen, str_ptr)
            let idx_val = llvm_generator_operand_to_value(gen, idx_op)
            
            mut dummy_lv = alloc LLVMValue()
            mut idx_list = new_list(1, dummy_lv)
            list_push(idx_list, idx_val^)
            
            mut i8_inner = alloc LLVMType()
            i8_inner^ = LLVMType.I8
            let char_ptr = ir_builder_build_gep(gen^.builder, i8_inner, str_val, idx_list)
            let raw_char = ir_builder_build_load(gen^.builder, char_ptr, 1)
            
            mut i64_ty = alloc LLVMType()
            i64_ty^ = LLVMType.I64
            let extended_char = ir_builder_build_zext(gen^.builder, raw_char, i64_ty)
            
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = extended_char
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
