    ir_builder_push_instr(b, LLVMInstruction.ICmp(dest, pred, ty, l, r))
    mut v = alloc LLVMValue()
    mut bool_ty = alloc LLVMType()
    bool_ty^ = LLVMType.I1
    v^ = LLVMValue.Reg(dest, bool_ty)
    return v
}

