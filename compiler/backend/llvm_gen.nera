data TypeInfoPtr { ptr: ^TypeInfo }
data LLVMValuePtr { ptr: ^LLVMValue }
data LLVMTypePtr { ptr: ^LLVMType }

// ==========================================
// IR BUILDER METHODS
// ==========================================
fn ir_builder_new(name: String) -> ^IRBuilder {
    mut b = alloc IRBuilder()
    mut mod = alloc LLVMModule()
    mod^.name = name
    mut dummy_fn = alloc LLVMFunction()
    mod^.funcs = new_list(10, dummy_fn)
    mut dummy_str = alloc String()
    dummy_str^ = ""
    mod^.declarations = new_list(10, dummy_str)
    mut dummy_gs = alloc LLVMGlobalString()
    mod^.global_strings = new_list(10, dummy_gs)
    
    b^.module = mod
    b^.active_func = None
    b^.active_block = None
    b^.reg_count = 1
    return b
}

fn ir_builder_declare(mut b: ^IRBuilder, decl: String) {
    mut exists = false
    mut i = 0
    while i < b^.module^.declarations^.length {
        let d = list_get(b^.module^.declarations, i)
        if string_eq(d, decl) { exists = true }
        i = i + 1
    }
    if not exists { list_push(b^.module^.declarations, decl) }
}

fn ir_builder_next_reg_name(mut b: ^IRBuilder) -> String {
    let r = b^.reg_count
    b^.reg_count = b^.reg_count + 1
    return int_to_string(r)
}

fn ir_builder_push_instr(mut b: ^IRBuilder, instr: LLVMInstruction) {
    mut blk_opt = b^.active_block
    if blk_opt != None {
        mut blk: ^LLVMBasicBlock = blk_opt
        mut instr_ptr = alloc LLVMInstruction()
        instr_ptr^ = instr
        puts(concat_strings("DEBUG BUILDER: pushing instr to block: ", blk^.name))
        list_push(blk^.instrs, instr)
    } else {
        puts("DEBUG BUILDER: active_block is NONE when pushing instruction!")
    }
}

fn ir_builder_start_function(mut b: ^IRBuilder, name: String, ret_ty: ^LLVMType, params: ^List(LLVMParam)) {
    b^.reg_count = 1
    mut func = alloc LLVMFunction()
    func^.name = name
    func^.ret_ty = ret_ty
    func^.params = params
    mut dummy_blk = alloc LLVMBasicBlock()
    func^.blocks = new_list(10, dummy_blk)
    mut dummy_instr = alloc LLVMInstruction()
    func^.allocas = new_list(10, dummy_instr)
    b^.active_func = func
}

fn ir_builder_end_function(mut b: ^IRBuilder) {
    mut blk_opt = b^.active_block
    if blk_opt != None {
        mut blk: ^LLVMBasicBlock = blk_opt
        mut fn_opt = b^.active_func
        if fn_opt != None {
            mut func: ^LLVMFunction = fn_opt
            puts(concat_strings(concat_strings("DEBUG BUILDER: end_function pushing block ", blk^.name), concat_strings(" to func: ", func^.name)))
            list_push(func^.blocks, blk^)
        }
        b^.active_block = None
    }
    mut fn_opt2 = b^.active_func
    if fn_opt2 != None {
        let func2: ^LLVMFunction = fn_opt2
        puts(concat_strings("DEBUG BUILDER: end_function pushing func: ", func2^.name))
        list_push(b^.module^.funcs, func2^)
        b^.active_func = None
    }
}

fn ir_builder_start_block(mut b: ^IRBuilder, name: String) {
    puts(concat_strings("DEBUG BUILDER: start_block: ", name))
    mut blk_opt = b^.active_block
    if blk_opt != None {
        mut blk: ^LLVMBasicBlock = blk_opt
        mut fn_opt = b^.active_func
        if fn_opt != None {
            mut func: ^LLVMFunction = fn_opt
            puts(concat_strings(concat_strings("DEBUG BUILDER: start_block pushing previous block ", blk^.name), concat_strings(" to func: ", func^.name)))
            list_push(func^.blocks, blk^)
        }
    }
    mut new_blk = alloc LLVMBasicBlock()
    new_blk^.name = name
    mut dummy_instr = alloc LLVMInstruction()
    new_blk^.instrs = new_list(10, dummy_instr)
    b^.active_block = new_blk
}

fn ir_builder_current_block_name(b: ^IRBuilder) -> String {
    mut blk_opt = b^.active_block
    if blk_opt != None {
        let blk: ^LLVMBasicBlock = blk_opt
        return blk^.name
    }
    return "entry"
}

fn ir_builder_build_alloca(mut b: ^IRBuilder, name: String, ty: ^LLVMType) -> ^LLVMValue {
    mut fn_opt = b^.active_func
    if fn_opt != None {
        mut func: ^LLVMFunction = fn_opt
        list_push(func^.allocas, LLVMInstruction.Alloca(name, ty))
    }
    mut v = alloc LLVMValue()
    mut ty_ptr = alloc LLVMType()
    ty_ptr^ = ty^
    mut pty = alloc LLVMType()
    pty^ = LLVMType.Pointer(ty_ptr)
    v^ = LLVMValue.Reg(name, pty)
    return v
}

fn ir_builder_build_load(mut b: ^IRBuilder, ptr: ^LLVMValue, align: Int) -> ^LLVMValue {
    let ptr_ty = llvm_value_get_type(ptr)
    mut ret_ty = alloc LLVMType()
    ret_ty^ = LLVMType.I64
    when ptr_ty^ { 
        Pointer(inner) -> { ret_ty = inner } 
        I1 -> {} I8 -> {} I32 -> {} I64 -> {} Double -> {} Void -> {} Array(s, i) -> {} Named(n) -> {} 
    }
    let dest = ir_builder_next_reg_name(b)
    ir_builder_push_instr(b, LLVMInstruction.Load(dest, ret_ty, ptr, align))
    mut v = alloc LLVMValue()
    v^ = LLVMValue.Reg(dest, ret_ty)
    return v
}

fn ir_builder_build_store(mut b: ^IRBuilder, val: ^LLVMValue, ptr: ^LLVMValue, align: Int) {
    ir_builder_push_instr(b, LLVMInstruction.Store(val, ptr, align))
}

fn ir_builder_build_gep(mut b: ^IRBuilder, base_ty: ^LLVMType, ptr: ^LLVMValue, indices: ^List(LLVMValue)) -> ^LLVMValue {
    let dest = ir_builder_next_reg_name(b)
    mut raw_ptr = alloc LLVMValue()
    raw_ptr^ = ptr^
    mut i8_inner = alloc LLVMType()
    i8_inner^ = LLVMType.I8
    mut pi8_ty = alloc LLVMType()
    pi8_ty^ = LLVMType.Pointer(i8_inner)
    
    when raw_ptr^ {
        Reg(name, t) -> { raw_ptr^ = LLVMValue.Reg(name, pi8_ty) }
        Global(name, t) -> { raw_ptr^ = LLVMValue.Global(name, pi8_ty) }
        ConstGlobalStringPtr(n_str, l_str) -> {} ConstI1(c_b) -> {} ConstI8(i_8) -> {} ConstI32(i_32) -> {} ConstI64(i_64) -> {} ConstDouble(f_d) -> {} Null(t_n) -> {}
    }
    
    mut ret_ty = alloc LLVMType()
    ret_ty^ = LLVMType.Pointer(base_ty)
    ir_builder_push_instr(b, LLVMInstruction.GetElementPtr(dest, base_ty, raw_ptr, indices))
    mut v = alloc LLVMValue()
    v^ = LLVMValue.Reg(dest, ret_ty)
    return v
}

fn ir_builder_build_add(mut b: ^IRBuilder, l: ^LLVMValue, r: ^LLVMValue) -> ^LLVMValue {
    let dest = ir_builder_next_reg_name(b)
    let ty = llvm_value_get_type(l)
    ir_builder_push_instr(b, LLVMInstruction.Add(dest, ty, l, r))
    mut v = alloc LLVMValue()
    v^ = LLVMValue.Reg(dest, ty)
    return v
}

