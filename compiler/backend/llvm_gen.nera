            let field_key = concat_strings(arr_name, concat_strings("_", prop_name))
            
            mut arr_ptr = alloc LLVMValue()
            mut ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, field_key)
            if ptr_opt != None {
                let w_val: LLVMValuePtr = ptr_opt
                mut w = alloc LLVMValuePtr()
