        StringCompare(dest, left_op, right_op, is_eq_flag) -> {
            let l_val = llvm_generator_operand_to_value(gen, left_op)
            let r_val = llvm_generator_operand_to_value(gen, right_op)
            
            mut dummy_lv = alloc LLVMValue()
            mut args = new_list(2, dummy_lv)
            list_push(args, l_val^)
            list_push(args, r_val^)
            
            mut i1_ty = alloc LLVMType()
            i1_ty^ = LLVMType.I1
            
            let cmp_res = ir_builder_build_call(gen^.builder, i1_ty, "string_starts_with", args)
            
            mut final_res = cmp_res
            if not is_eq_flag {
                mut one = alloc LLVMValue()
                one^ = LLVMValue.ConstI1(true)
                final_res = ir_builder_build_xor(gen^.builder, cmp_res, one)
            }
            
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = final_res
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
            }
        }
        FlatVectorApply(target_array, ops, start_op, end_op, size) -> {
            let s_val = llvm_generator_operand_to_value(gen, start_op)
            let e_val = llvm_generator_operand_to_value(gen, end_op)
            
            mut i64_ty = alloc LLVMType()
            i64_ty^ = LLVMType.I64
            let idx_ptr = ir_builder_build_alloca(gen^.builder, ir_builder_next_reg_name(gen^.builder), i64_ty)
            ir_builder_build_store(gen^.builder, s_val, idx_ptr, 8)
            
            let cond_lbl = concat_strings("vloop.cond.", ir_builder_next_reg_name(gen^.builder))
            let body_lbl = concat_strings("vloop.body.", ir_builder_next_reg_name(gen^.builder))
            let end_lbl = concat_strings("vloop.end.", ir_builder_next_reg_name(gen^.builder))
            
            ir_builder_build_br(gen^.builder, cond_lbl, "")
            
            ir_builder_start_block(gen^.builder, cond_lbl)
            let current_idx = ir_builder_build_load(gen^.builder, idx_ptr, 8)
            let cmp_res = ir_builder_build_icmp(gen^.builder, "slt", current_idx, e_val)
            ir_builder_build_cond_br(gen^.builder, cmp_res, body_lbl, end_lbl, "")
            
            ir_builder_start_block(gen^.builder, body_lbl)
            
            mut k = 0
            while k < ops^.length {
                let op_val = list_get(ops, k)
                mut op = alloc FlatVectorApplyOp()
                op^ = op_val
                let field_key = concat_strings(target_array, concat_strings("_", op^.prop))
                
                mut arr_var_ptr = alloc LLVMValue()
                mut ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, field_key)
                if ptr_opt != None {
                    let w_val: LLVMValuePtr = ptr_opt
                    mut w = alloc LLVMValuePtr()
                    w^ = w_val
                    arr_var_ptr = w^.ptr
                }
                let base_array_ptr = ir_builder_build_load(gen^.builder, arr_var_ptr, 8)
                
                mut eight = alloc LLVMValue()
                eight^ = LLVMValue.ConstI64(8)
                let byte_offset = ir_builder_build_mul(gen^.builder, current_idx, eight)
                
                mut dummy_lv = alloc LLVMValue()
                mut idx_list = new_list(1, dummy_lv)
                list_push(idx_list, byte_offset^)
                
                mut i8_inner = alloc LLVMType()
                i8_inner^ = LLVMType.I8
                let target_element_ptr = ir_builder_build_gep(gen^.builder, i8_inner, base_array_ptr, idx_list)
                
                mut pi64_ty = alloc LLVMType()
                pi64_ty^ = LLVMType.Pointer(i64_ty)
                let casted_target_ptr = ir_builder_build_bitcast(gen^.builder, target_element_ptr, pi64_ty)
                
                let old_val = ir_builder_build_load(gen^.builder, casted_target_ptr, 8)
                
                mut rhs_val = old_val
                mut operand_ptr = alloc VectorOperand()
                operand_ptr^ = op^.operand
                when operand_ptr^ {
                    Scalar(scalar_op) -> {
                        rhs_val = llvm_generator_operand_to_value(gen, scalar_op)
                    }
                    Vector(rhs_arr, rhs_prop) -> {
                        let rhs_key = concat_strings(rhs_arr, concat_strings("_", rhs_prop))
                        mut rhs_var_ptr = alloc LLVMValue()
                        mut r_ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, rhs_key)
                        if r_ptr_opt != None {
                            let rw_val: LLVMValuePtr = r_ptr_opt
                            mut rw = alloc LLVMValuePtr()
                            rw^ = rw_val
                            rhs_var_ptr = rw^.ptr
                        }
                        
                        let r_base = ir_builder_build_load(gen^.builder, rhs_var_ptr, 8)
                        mut r_idx_list = new_list(1, dummy_lv)
                        list_push(r_idx_list, byte_offset^)
                        
                        let r_element_ptr = ir_builder_build_gep(gen^.builder, i8_inner, r_base, r_idx_list)
                        let r_casted = ir_builder_build_bitcast(gen^.builder, r_element_ptr, pi64_ty)
                        rhs_val = ir_builder_build_load(gen^.builder, r_casted, 8)
                    }
                }
                
                mut final_computed_val = rhs_val
                let assign_op = op^.op
                when assign_op {
                    Assign -> {}
                    AddAssign -> { final_computed_val = ir_builder_build_add(gen^.builder, old_val, rhs_val) }
                    SubAssign -> { final_computed_val = ir_builder_build_sub(gen^.builder, old_val, rhs_val) }
                    MulAssign -> { final_computed_val = ir_builder_build_mul(gen^.builder, old_val, rhs_val) }
                    DivAssign -> { final_computed_val = ir_builder_build_sdiv(gen^.builder, old_val, rhs_val) }
                }
                
                ir_builder_build_store(gen^.builder, final_computed_val, casted_target_ptr, 8)
                k = k + 1
            }
            
            mut one = alloc LLVMValue()
            one^ = LLVMValue.ConstI64(1)
            let next_idx = ir_builder_build_add(gen^.builder, current_idx, one)
            ir_builder_build_store(gen^.builder, next_idx, idx_ptr, 8)
            
            ir_builder_build_br(gen^.builder, cond_lbl, "")
            
            ir_builder_start_block(gen^.builder, end_lbl)
        }
        LoadPointer(dest, ptr) -> {
            let ptr_val = llvm_generator_operand_to_value(gen, ptr)
            
            mut is_custom_or_choice = false
            mut is_parameter = false
            when ptr^ {
                Variable(name) -> {
                    is_parameter = string_set_contains(gen^.parameter_names, name)
                    if not is_parameter {
                        mut ty_opt: ?TypeInfoPtr = hashmap_get(gen^.type_env, name)
                        if ty_opt != None {
                            let tw_val: TypeInfoPtr = ty_opt
                            mut tw = alloc TypeInfoPtr()
                            tw^ = tw_val
                            let ty = tw^.ptr
                            when ty^ {
                                Pointer(inner) -> {
                                    is_custom_or_choice = llvm_generator_is_custom_or_choice_type(gen, inner)
                                }
                                Custom(cs) -> {
                                    is_custom_or_choice = true
                                }
                                Unknown -> {} Int -> {} Float -> {} Boolean -> {} String -> {} Array(arr) -> {} Void -> {} NoneVariant -> {} Char -> {} Nullable(inner) -> {}
                            }
                        }
                    }
                }
                TempReg(t) -> {} LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Void -> {} NoneLiteral -> {}
            }
            
            mut loaded_val = ptr_val
            if not is_custom_or_choice {
                loaded_val = ir_builder_build_load(gen^.builder, ptr_val, 0)
            }
            
            when dest^ {
                Variable(name) -> {
                    mut ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, name)
                    if ptr_opt != None {
                        let ptr_wrap_val: LLVMValuePtr = ptr_opt
                        mut ptr_wrap = alloc LLVMValuePtr()
                        ptr_wrap^ = ptr_wrap_val
                        ir_builder_build_store(gen^.builder, loaded_val, ptr_wrap^.ptr, 0)
                    } else {
                        mut vw = alloc LLVMValuePtr()
                        vw^.ptr = loaded_val
                        hashmap_put(gen^.function_params, name, vw^)
                    }
                }
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = loaded_val
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
            }
        }
        StorePointer(dest_ptr, source_val) -> {
            let ptr_val = llvm_generator_operand_to_value(gen, dest_ptr)
            let val_val = llvm_generator_operand_to_value(gen, source_val)
            ir_builder_build_store(gen^.builder, val_val, ptr_val, 0)
        }
        Cast(dest, target_type, src) -> {
            let src_val = llvm_generator_operand_to_value(gen, src)
            let src_ty = llvm_value_get_type(src_val)
            let dest_ty = llvm_generator_str_to_llvm_type(gen, target_type)
            
            mut casted_val = src_val
            
            when src_ty^ {
                I64 -> {
                    when dest_ty^ {
                        Double -> {
                            mut d_ty = alloc LLVMType()
                            d_ty^ = LLVMType.Double
                            casted_val = ir_builder_build_sitofp(gen^.builder, src_val, d_ty)
                        }
                        I1 -> {
                            mut zero = alloc LLVMValue()
                            zero^ = LLVMValue.ConstI64(0)
                            casted_val = ir_builder_build_icmp(gen^.builder, "ne", src_val, zero)
                        }
                        I64 -> {}
                        I1 -> {} I8 -> {} I32 -> {} Pointer(i) -> {} Void -> {} Array(s, i) -> {} Named(n) -> {}
                    }
                }
                Double -> {
                    when dest_ty^ {
                        I64 -> {
                            mut i_ty = alloc LLVMType()
                            i_ty^ = LLVMType.I64
                            casted_val = ir_builder_build_fptosi(gen^.builder, src_val, i_ty)
                        }
                        I1 -> {} I8 -> {} I32 -> {} Double -> {} Pointer(i) -> {} Void -> {} Array(s, i) -> {} Named(n) -> {}
                    }
                }
                I1 -> {
                    when dest_ty^ {
                        I64 -> {
                            mut i_ty = alloc LLVMType()
                            i_ty^ = LLVMType.I64
                            casted_val = ir_builder_build_zext(gen^.builder, src_val, i_ty)
                        }
                        I1 -> {} I8 -> {} I32 -> {} Double -> {} Pointer(i) -> {} Void -> {} Array(s, i) -> {} Named(n) -> {}
                    }
                }
                I8 -> {} I32 -> {} Pointer(inner) -> {} Void -> {} Array(sz, inner_arr) -> {} Named(named_str) -> {}
            }
            
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = casted_val
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
            }
        }
    }
}

fn llvm_generator_lower_function(mut gen: ^LLVMGenerator, func: ^IRFunction) {
    let sanitized_name = string_replace(string_replace(string_replace(string_replace(func^.name, "(", "_"), ")", ""), ", ", "_"), "^", "Ptr")
    
    mut final_name = sanitized_name
    if string_eq(func^.name, "main") {
        final_name = "nera_main"
    }
    
    gen^.parameter_names = new_string_set()
    
    let ret_ty = llvm_generator_return_type_str_to_llvm(gen, func^.return_type)
    
    mut dummy_param = alloc LLVMParam()
    mut params = new_list(10, dummy_param)
    
    mut p_idx = 0
    while p_idx < func^.params^.length {
        let ir_param = list_get(func^.params, p_idx)
        string_set_add(gen^.parameter_names, ir_param.name)
        
        mut llvm_p = alloc LLVMParam()
        
        let is_scalar = (string_contains(ir_param.name, "soa_") == false) and (string_contains(ir_param.name, "_") == false)
        if is_scalar {
            llvm_p^.name = concat_strings("param_", ir_param.name)
        } else {
            llvm_p^.name = ir_param.name
        }
        
        llvm_p^.ty = llvm_generator_return_type_str_to_llvm(gen, ir_param.ty)
        list_push(params, llvm_p^)
        
        if is_scalar {
            string_set_add(gen^.scalar_vars, ir_param.name)
        }
        p_idx = p_idx + 1
    }
    
    ir_builder_declare(gen^.builder, "declare i8* @malloc(i64)")
    ir_builder_declare(gen^.builder, "declare void @free(i8*)")
    
    if func^.is_extern {
        mut sig = concat_strings("declare ", llvm_type_to_string(ret_ty))
        sig = concat_strings(sig, concat_strings(" @", final_name))
        sig = concat_strings(sig, "()")
        ir_builder_declare(gen^.builder, sig)
        return
    }
    
    ir_builder_start_function(gen^.builder, final_name, ret_ty, params)
    
    mut b = 0
    while b < func^.blocks^.length {
        let block_val = list_get(func^.blocks, b)
        mut block = alloc BasicBlock()
        block^ = block_val
        ir_builder_start_block(gen^.builder, block^.name)
        
        mut i = 0
        while i < block^.instrs^.length {
            let instr = list_get(block^.instrs, i)
            mut instr_ptr = alloc IRInstruction()
            instr_ptr^ = instr
            puts(concat_strings(concat_strings("  LOWERING IR tag: ", int_to_string(get_choice_tag_ir(instr_ptr))), concat_strings(" in func: ", final_name)))
            llvm_generator_lower_instruction(gen, instr_ptr)
            i = i + 1
        }
        
        when block^.terminator {
            Jump(tgt) -> { ir_builder_build_br(gen^.builder, tgt, "") }
            Branch(cond, t_tgt, f_tgt) -> {
                let cond_val = llvm_generator_operand_to_value(gen, cond)
                ir_builder_build_cond_br(gen^.builder, cond_val, t_tgt, f_tgt, "")
            }
            Return(val_opt) -> {
                if val_opt != None {
                    let v: ^IROperand = val_opt
                    let ret_val = llvm_generator_operand_to_value(gen, v)
                    
                    mut ret_val_ptr = alloc LLVMValue()
                    ret_val_ptr^ = ret_val^
                    
                    mut wrapped_opt: ?^LLVMValue = None
                    wrapped_opt = ret_val_ptr
                    ir_builder_build_ret(gen^.builder, wrapped_opt)
                } else {
                    mut none_opt: ?^LLVMValue = None
                    ir_builder_build_ret(gen^.builder, none_opt)
                }
            }
            None -> { ir_builder_build_unreachable(gen^.builder) }
        }
        
        b = b + 1
    }
    
    ir_builder_end_function(gen^.builder)
}

fn llvm_generator_generate(mut gen: ^LLVMGenerator, opt_ir: ^OptimizedIR, data_structs: ^List(^DataStructInfo)) -> String {
    gen^.data_structs = data_structs
    mut f = 0
    while f < opt_ir^.functions^.length {
        let func_val = list_get(opt_ir^.functions, f)
        mut func_ptr = alloc IRFunction()
        func_ptr^ = func_val
        llvm_generator_lower_function(gen, func_ptr)
        f = f + 1
    }
    
    mut out = ""
    out = concat_strings(out, "; ModuleID = 'nera_program'\n")
    out = concat_strings(out, "target datalayout = \"e-m:e-i64:64-f80:128-n8:16:32:64-S128\"\n")
    out = concat_strings(out, "target triple = \"x86_64-pc-linux-gnu\"\n\n")
    
    mut i = 0
    while i < gen^.builder^.module^.declarations^.length {
        let decl = list_get(gen^.builder^.module^.declarations, i)
        out = concat_strings(out, concat_strings(decl, "\n"))
        i = i + 1
    }
    out = concat_strings(out, "\n")
    
    mut j = 0
    while j < gen^.builder^.module^.global_strings^.length {
        let gs_val = list_get(gen^.builder^.module^.global_strings, j)
        mut gs = alloc LLVMGlobalString()
        gs^ = gs_val
        out = concat_strings(out, concat_strings("@", gs^.name))
        out = concat_strings(out, concat_strings(" = private unnamed_addr constant [", int_to_string(gs^.len)))
        out = concat_strings(out, concat_strings(" x i8] c\"", gs^.val))
        out = concat_strings(out, "\", align 1\n")
        j = j + 1
    }
    out = concat_strings(out, "\n")
    
    mut k = 0
    while k < gen^.builder^.module^.funcs^.length {
        let func_val = list_get(gen^.builder^.module^.funcs, k)
        mut func = alloc LLVMFunction()
        func^ = func_val
        out = concat_strings(out, concat_strings("define ", llvm_type_to_string(func^.ret_ty)))
        out = concat_strings(out, concat_strings(" @", func^.name))
        out = concat_strings(out, "() {\n")
        
        mut b = 0
        while b < func^.blocks^.length {
            let blk_val = list_get(func^.blocks, b)
            mut blk = alloc LLVMBasicBlock()
            blk^ = blk_val
            out = concat_strings(out, concat_strings(blk^.name, ":\n"))
            if b == 0 {
                mut a = 0
                while a < func^.allocas^.length {
                    let alloca_instr = list_get(func^.allocas, a)
                    mut instr_ptr = alloc LLVMInstruction()
                    instr_ptr^ = alloca_instr
                    out = concat_strings(out, concat_strings(llvm_instr_to_string(instr_ptr), "\n"))
                    a = a + 1
                }
            }
            mut instr_idx = 0
            puts(concat_strings(concat_strings("DEBUG GENERATE: Block ", blk^.name), concat_strings(" instrs length: ", int_to_string(blk^.instrs^.length))))
            while instr_idx < blk^.instrs^.length {
                let instr = list_get(blk^.instrs, instr_idx)
                mut instr_ptr = alloc LLVMInstruction()
                instr_ptr^ = instr
                puts(concat_strings(concat_strings("  INSTR (tag ", int_to_string(get_choice_tag(instr_ptr))), concat_strings("): ", llvm_instr_to_string(instr_ptr))))
                out = concat_strings(out, concat_strings(llvm_instr_to_string(instr_ptr), "\n"))
                instr_idx = instr_idx + 1
            }
            b = b + 1
        }
        out = concat_strings(out, "}\n\n")
        k = k + 1
    }
    
    return out
}