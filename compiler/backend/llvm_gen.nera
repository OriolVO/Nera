        StoreStructField(ptr_op, field_idx, val_op) -> {
            let ptr_val = llvm_generator_operand_to_value(gen, ptr_op)
            let val_val = llvm_generator_operand_to_value(gen, val_op)
            
            mut idx_val = alloc LLVMValue()
