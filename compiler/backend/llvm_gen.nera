fn ir_builder_build_call(mut b: ^IRBuilder, ret_ty: ^LLVMType, name: String, args: ^List(LLVMValue)) -> ^LLVMValue {
    mut dest_opt: ?String = None
    mut v = alloc LLVMValue()
    when ret_ty^ {
        Void -> { v^ = LLVMValue.Null(ret_ty) }
        I1 -> {
            let dest = ir_builder_next_reg_name(b)
            dest_opt = dest
            v^ = LLVMValue.Reg(dest, ret_ty)
        }
        I8 -> {
            let dest = ir_builder_next_reg_name(b)
            dest_opt = dest
            v^ = LLVMValue.Reg(dest, ret_ty)
        }
        I32 -> {
            let dest = ir_builder_next_reg_name(b)
            dest_opt = dest
            v^ = LLVMValue.Reg(dest, ret_ty)
        }
        I64 -> {
            let dest = ir_builder_next_reg_name(b)
            dest_opt = dest
            v^ = LLVMValue.Reg(dest, ret_ty)
        }
        Double -> {
            let dest = ir_builder_next_reg_name(b)
            dest_opt = dest
            v^ = LLVMValue.Reg(dest, ret_ty)
        }
        Pointer(i) -> {
            let dest = ir_builder_next_reg_name(b)
            dest_opt = dest
            v^ = LLVMValue.Reg(dest, ret_ty)
        }
        Array(s, i) -> {}
        Named(n) -> {}
    }
    ir_builder_push_instr(b, LLVMInstruction.Call(dest_opt, ret_ty, name, args))
    return v
}

fn ir_builder_build_br(mut b: ^IRBuilder, lbl: String, meta: String) {
    ir_builder_push_instr(b, LLVMInstruction.Br(lbl, meta))
}

fn ir_builder_build_cond_br(mut b: ^IRBuilder, cond: ^LLVMValue, t_lbl: String, f_lbl: String, meta: String) {
    ir_builder_push_instr(b, LLVMInstruction.CondBr(cond, t_lbl, f_lbl, meta))
}

fn ir_builder_build_ret(mut b: ^IRBuilder, val_opt: ?^LLVMValue) {
    ir_builder_push_instr(b, LLVMInstruction.Ret(val_opt))
}

fn ir_builder_build_unreachable(mut b: ^IRBuilder) {
    ir_builder_push_instr(b, LLVMInstruction.Unreachable)
}

fn ir_builder_build_global_string_ptr(mut b: ^IRBuilder, value: String) -> ^LLVMValue {
    let name = concat_strings(".str.", int_to_string(b^.module^.global_strings^.length))
    let len = 32
    mut gs = alloc LLVMGlobalString()
    gs^.name = name
    gs^.val = value
    gs^.len = len
    list_push(b^.module^.global_strings, gs^)
    mut v = alloc LLVMValue()
    v^ = LLVMValue.ConstGlobalStringPtr(name, len)
    return v
}

// ==========================================
// LLVM GENERATOR
// ==========================================

data DataStructInfo {
    name: String
    fields: ^List(String)
}

data LLVMGenerator {
    type_env: ^HashMap(TypeInfoPtr)
    builder: ^IRBuilder
    temp_map: ^HashMap(LLVMValuePtr)
    function_params: ^HashMap(LLVMValuePtr)
    scalar_vars: ^StringSet
    parameter_names: ^StringSet
    main_arena_ptr: ?^LLVMValue
    shared_vec_idx: ?^LLVMValue
    func_ret_types: ^HashMap(LLVMTypePtr)
    actual_soa_arrays: ^List(SoAArray)
    data_structs: ^List(^DataStructInfo)
}

fn llvm_generator_new() -> ^LLVMGenerator {
    mut gen = alloc LLVMGenerator()
    
    mut dummy_tip = alloc TypeInfoPtr()
    gen^.type_env = new_hashmap(dummy_tip)
    
    gen^.builder = ir_builder_new("nera_program")
    
    mut dummy_lvp = alloc LLVMValuePtr()
    gen^.temp_map = new_hashmap(dummy_lvp)
    gen^.function_params = new_hashmap(dummy_lvp)
    
    gen^.scalar_vars = new_string_set()
    gen^.parameter_names = new_string_set()
    gen^.main_arena_ptr = None
    gen^.shared_vec_idx = None
    
    mut dummy_ltp = alloc LLVMTypePtr()
    gen^.func_ret_types = new_hashmap(dummy_ltp)
    
    mut dummy_soa = alloc SoAArray()
    gen^.actual_soa_arrays = new_list(10, dummy_soa)
    
    mut dummy_ds = alloc ^DataStructInfo()
    gen^.data_structs = new_list(10, dummy_ds)
    
    return gen
}

fn llvm_generator_get_struct_name(gen: ^LLVMGenerator, ty: ^TypeInfo) -> ?String {
    when ty^ {
        Custom(name) -> {
            mut ret: ?String = None
            ret = name
            return ret
        }
        Pointer(inner) -> {
            return llvm_generator_get_struct_name(gen, inner)
        }
        Nullable(inner) -> {
            return llvm_generator_get_struct_name(gen, inner)
        }
        Int -> {} Float -> {} Boolean -> {} String -> {} Char -> {} Void -> {} Array(a) -> {} Unknown -> {} NoneVariant -> {}
    }
    mut ret: ?String = None
    return ret
}

fn llvm_generator_is_custom_struct(gen: ^LLVMGenerator, struct_name: String) -> Boolean {
    mut i = 0
    while i < gen^.data_structs^.length {
        let info = list_get(gen^.data_structs, i)
        if info^.name == struct_name {
            return true
        }
        i = i + 1
    }
    return false
}

fn llvm_generator_get_field_index(gen: ^LLVMGenerator, struct_name: String, prop: String) -> Int {
    mut i = 0
    while i < gen^.data_structs^.length {
        let info = list_get(gen^.data_structs, i)
        if info^.name == struct_name {
            mut j = 0
            while j < info^.fields^.length {
                let f = list_get(info^.fields, j)
                if f == prop {
                    return j
                }
                j = j + 1
            }
            return -1
        }
        i = i + 1
    }
    return -1
}

fn llvm_generator_str_to_llvm_type(gen: ^LLVMGenerator, ty_str: String) -> ^LLVMType {
    mut ret = alloc LLVMType()
    if string_eq(ty_str, "Int") or string_eq(ty_str, "Char") {
        ret^ = LLVMType.I64
    } else if string_eq(ty_str, "Float") {
        ret^ = LLVMType.Double
    } else if string_eq(ty_str, "Boolean") {
        ret^ = LLVMType.I1
    } else if string_eq(ty_str, "String") {
        mut inner = alloc LLVMType()
        inner^ = LLVMType.I8
        ret^ = LLVMType.Pointer(inner)
    } else {
        mut inner = alloc LLVMType()
        inner^ = LLVMType.I8
        ret^ = LLVMType.Pointer(inner)
    }
    return ret
}

fn llvm_generator_type_to_llvm(gen: ^LLVMGenerator, nera_ty: ^TypeInfo) -> ^LLVMType {
    mut ret = alloc LLVMType()
    when nera_ty^ {
        Int -> { ret^ = LLVMType.I64 }
        Float -> { ret^ = LLVMType.Double }
        Boolean -> { ret^ = LLVMType.I1 }
        String -> {
            mut inner = alloc LLVMType()
            inner^ = LLVMType.I8
            ret^ = LLVMType.Pointer(inner)
        }
        Array(arr_info) -> {
            let a_info: ^TypeInfoArray = arr_info
            let i_ll = llvm_generator_type_to_llvm(gen, a_info^.inner)
            ret^ = LLVMType.Pointer(i_ll)
        }
        Pointer(inner) -> {
            let i_ll = llvm_generator_type_to_llvm(gen, inner)
            ret^ = LLVMType.Pointer(i_ll)
        }
        Void -> { ret^ = LLVMType.Void }
        Custom(s) -> {
            mut inner = alloc LLVMType()
            inner^ = LLVMType.I64
            ret^ = LLVMType.Pointer(inner)
        }
        Nullable(inner) -> { ret^ = LLVMType.I64 }
        NoneVariant -> {
            mut inner = alloc LLVMType()
            inner^ = LLVMType.I8
            ret^ = LLVMType.Pointer(inner)
        }
        Char -> { ret^ = LLVMType.I64 }
        Unknown -> { ret^ = LLVMType.I64 }
    }
    return ret
}

fn llvm_generator_is_custom_or_choice_type(gen: ^LLVMGenerator, nera_ty: ^TypeInfo) -> Boolean {
    when nera_ty^ {
        Custom(s) -> { return true }
        Pointer(inner) -> { return llvm_generator_is_custom_or_choice_type(gen, inner) }
        Nullable(inner) -> { return llvm_generator_is_custom_or_choice_type(gen, inner) }
        Int -> {} Float -> {} Boolean -> {} String -> {} Array(arr) -> {} Void -> {} NoneVariant -> {} Char -> {} Unknown -> {}
    }
    return false
}

fn llvm_generator_return_type_str_to_llvm(gen: ^LLVMGenerator, ret_type_str: String) -> ^LLVMType {
    mut s = ret_type_str
    let is_nullable = string_starts_with(s, "?")
    if is_nullable { s = string_substring(s, 1, 999) }
    let is_ptr = string_starts_with(s, "^")
    if is_ptr { s = string_substring(s, 1, 999) }
    
    mut ret_info = alloc TypeInfo()
    if string_eq(s, "Int") { ret_info^ = TypeInfo.Int }
    else if string_eq(s, "Float") { ret_info^ = TypeInfo.Float }
    else if string_eq(s, "Boolean") { ret_info^ = TypeInfo.Boolean }
    else if string_eq(s, "String") { ret_info^ = TypeInfo.String }
    else if string_eq(s, "Char") { ret_info^ = TypeInfo.Int }
    else if string_eq(s, "Void") { ret_info^ = TypeInfo.Void }
    else { ret_info^ = TypeInfo.Custom(s) }
    
    if is_ptr {
        mut p = alloc TypeInfo()
        p^ = TypeInfo.Pointer(ret_info)
        ret_info = p
    }
    if is_nullable {
        mut p = alloc TypeInfo()
        p^ = TypeInfo.Nullable(ret_info)
        ret_info = p
    }
    
    return llvm_generator_type_to_llvm(gen, ret_info)
}

fn llvm_generator_operand_to_value(mut gen: ^LLVMGenerator, op: ^IROperand) -> ^LLVMValue {
    mut ret = alloc LLVMValue()
    when op^ {
        LiteralInt(v) -> { ret^ = LLVMValue.ConstI64(v) }
        LiteralFloat(v) -> { ret^ = LLVMValue.ConstDouble(v) }
        LiteralString(v) -> { ret = ir_builder_build_global_string_ptr(gen^.builder, v) }
        LiteralChar(v) -> { 
            let int_char_val = char_to_int(v)
            ret^ = LLVMValue.ConstI64(int_char_val) 
        }
        LiteralBool(v) -> { ret^ = LLVMValue.ConstI1(v) }
        Variable(name) -> {
            mut ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, name)
            if ptr_opt != None {
                let ptr_wrap_val: LLVMValuePtr = ptr_opt
                mut ptr_wrap = alloc LLVMValuePtr()
                ptr_wrap^ = ptr_wrap_val
                let ptr = ptr_wrap^.ptr
                let is_scalar = string_set_contains(gen^.scalar_vars, name) or string_starts_with(name, "param_")
                if is_scalar {
                    ret = ir_builder_build_load(gen^.builder, ptr, 0)
                } else {
                    ret = ptr
                }
            } else {
                mut ty = alloc TypeInfo()
                ty^ = TypeInfo.Int
                mut ty_opt: ?TypeInfoPtr = hashmap_get(gen^.type_env, name)
                if ty_opt != None {
                    let tw_val: TypeInfoPtr = ty_opt
                    mut tw = alloc TypeInfoPtr()
                    tw^ = tw_val
                    ty = tw^.ptr
                }
                ret^ = LLVMValue.Reg(name, llvm_generator_type_to_llvm(gen, ty))
            }
        }
        TempReg(t) -> {
            let t_name = int_to_string(t)
            mut v_opt: ?LLVMValuePtr = hashmap_get(gen^.temp_map, t_name)
            if v_opt != None {
                let vw_val: LLVMValuePtr = v_opt
                mut vw = alloc LLVMValuePtr()
                vw^ = vw_val
                ret = vw^.ptr
            } else {
                mut lty = alloc LLVMType()
                lty^ = LLVMType.I64
                ret^ = LLVMValue.Reg(concat_strings("t", t_name), lty)
            }
        }
        Void -> {
            mut vty = alloc LLVMType()
            vty^ = LLVMType.Void
            ret^ = LLVMValue.Null(vty)
        }
        NoneLiteral -> {
            mut vty = alloc LLVMType()
            vty^ = LLVMType.I8
            mut pty = alloc LLVMType()
            pty^ = LLVMType.Pointer(vty)
            ret^ = LLVMValue.Null(pty)
        }
    }
    return ret
}

fn llvm_generator_lower_instruction(mut gen: ^LLVMGenerator, instr: ^IRInstruction) {
    when instr^ {
        Assign(dest, src) -> {
            puts("DEBUG LOWER: entered Assign arm")
            let src_val = llvm_generator_operand_to_value(gen, src)
            when dest^ {
                Variable(name) -> {
                    mut ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, name)
                    if ptr_opt != None {
                        let ptr_wrap_val: LLVMValuePtr = ptr_opt
                        mut ptr_wrap = alloc LLVMValuePtr()
                        ptr_wrap^ = ptr_wrap_val
                        ir_builder_build_store(gen^.builder, src_val, ptr_wrap^.ptr, 0)
                    } else {
                        mut vw = alloc LLVMValuePtr()
                        vw^.ptr = src_val
                        hashmap_put(gen^.function_params, name, vw^)
                    }
                }
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = src_val
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(i) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Void -> {} NoneLiteral -> {}
            }
        }
        UnaryOp(dest, op, operand) -> {
            let op_val = llvm_generator_operand_to_value(gen, operand)
            mut res = op_val
            when op {
                Negate -> {
                    mut zero = alloc LLVMValue()
                    zero^ = LLVMValue.ConstI64(0)
                    res = ir_builder_build_sub(gen^.builder, zero, op_val)
                }
                Not -> {
                    mut one = alloc LLVMValue()
                    one^ = LLVMValue.ConstI1(true)
                    res = ir_builder_build_xor(gen^.builder, op_val, one)
                }
            }
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = res
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(i) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
            }
        }
        BinaryOp(dest, op, left, right) -> {
            puts("DEBUG LOWER: entered BinaryOp arm")
            let l_val = llvm_generator_operand_to_value(gen, left)
            let r_val = llvm_generator_operand_to_value(gen, right)
            mut res = l_val
            when op {
                Add -> { res = ir_builder_build_add(gen^.builder, l_val, r_val) }
                Sub -> { res = ir_builder_build_sub(gen^.builder, l_val, r_val) }
                Mul -> { res = ir_builder_build_mul(gen^.builder, l_val, r_val) }
                Div -> { res = ir_builder_build_sdiv(gen^.builder, l_val, r_val) }
                Mod -> { res = ir_builder_build_srem(gen^.builder, l_val, r_val) }
                Eq -> { res = ir_builder_build_icmp(gen^.builder, "eq", l_val, r_val) }
                NotEq -> { res = ir_builder_build_icmp(gen^.builder, "ne", l_val, r_val) }
                Lt -> { res = ir_builder_build_icmp(gen^.builder, "slt", l_val, r_val) }
                LtEq -> { res = ir_builder_build_icmp(gen^.builder, "sle", l_val, r_val) }
                Gt -> { res = ir_builder_build_icmp(gen^.builder, "sgt", l_val, r_val) }
                GtEq -> { res = ir_builder_build_icmp(gen^.builder, "sge", l_val, r_val) }
                And -> { res = ir_builder_build_and(gen^.builder, l_val, r_val) }
                Or -> { res = ir_builder_build_or(gen^.builder, l_val, r_val) }
                BitAnd -> { res = ir_builder_build_and(gen^.builder, l_val, r_val) }
                BitOr -> { res = ir_builder_build_or(gen^.builder, l_val, r_val) }
                BitXor -> { res = ir_builder_build_xor(gen^.builder, l_val, r_val) }
                Shl -> { res = ir_builder_build_shl(gen^.builder, l_val, r_val) }
                Shr -> { res = ir_builder_build_ashr(gen^.builder, l_val, r_val) }
                Pipe -> {}
            }
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = res
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(i) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
            }
        }
        LoadProperty(dest, obj, prop) -> {
            mut raw_name = ""
            when obj^ {
                Variable(n) -> { raw_name = n }
                LiteralInt(i) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} TempReg(t) -> {} Void -> {} NoneLiteral -> {}
            }
            let field_key = concat_strings(raw_name, concat_strings("_", prop))
            
            let is_soa = hashmap_get(gen^.function_params, field_key) != None
            
            mut is_custom_struct = false
            mut struct_name = ""
            
            if not is_soa {
                mut ty_opt: ?TypeInfoPtr = hashmap_get(gen^.type_env, raw_name)
                if ty_opt != None {
                    let tw_val: TypeInfoPtr = ty_opt
                    mut tw = alloc TypeInfoPtr()
                    tw^ = tw_val
                    let var_ty = tw^.ptr
                    let s_name_opt = llvm_generator_get_struct_name(gen, var_ty)
                    if s_name_opt != None {
                        let s_name: String = s_name_opt
                        if llvm_generator_is_custom_struct(gen, s_name) {
                            is_custom_struct = true
                            struct_name = s_name
                        }
                    }
                }
            }
            
            mut loaded = alloc LLVMValue()
            if is_custom_struct {
                let heap_ptr = llvm_generator_operand_to_value(gen, obj)
                
                mut i64_inner = alloc LLVMType()
                i64_inner^ = LLVMType.I64
                mut pi64_ty = alloc LLVMType()
                pi64_ty^ = LLVMType.Pointer(i64_inner)
                let casted_i64_ptr = ir_builder_build_bitcast(gen^.builder, heap_ptr, pi64_ty)
                
                let index = llvm_generator_get_field_index(gen, struct_name, prop)
                mut idx_vals = new_list(1, heap_ptr)
                mut idx_const = alloc LLVMValue()
                idx_const^ = LLVMValue.ConstI64(index)
                list_push(idx_vals, idx_const^)
                let element_ptr = ir_builder_build_gep(gen^.builder, i64_inner, casted_i64_ptr, idx_vals)
                
                // Get field type from type environment or fallback to Int
                mut field_ty = alloc TypeInfo()
                field_ty^ = TypeInfo.Int
                mut f_ty_opt: ?TypeInfoPtr = hashmap_get(gen^.type_env, field_key)
                if f_ty_opt == None {
                    f_ty_opt = hashmap_get(gen^.type_env, raw_name)
                }
                if f_ty_opt != None {
                    let f_tw: TypeInfoPtr = f_ty_opt
                    mut f_tw_alloc = alloc TypeInfoPtr()
                    f_tw_alloc^ = f_tw
                    field_ty = f_tw_alloc^.ptr
                }
                let target_llvm_ty = llvm_generator_type_to_llvm(gen, field_ty)
                mut ptarget_ty = alloc LLVMType()
                ptarget_ty^ = LLVMType.Pointer(target_llvm_ty)
                let target_ptr = ir_builder_build_bitcast(gen^.builder, element_ptr, ptarget_ty)
                
                loaded = ir_builder_build_load(gen^.builder, target_ptr, 8)
            } else {
                mut arr_ptr = alloc LLVMValue()
                mut ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, field_key)
                if ptr_opt == None {
                    ptr_opt = hashmap_get(gen^.function_params, raw_name)
                }
                if ptr_opt != None {
                    let w_val: LLVMValuePtr = ptr_opt
                    mut w = alloc LLVMValuePtr()
                    w^ = w_val
                    arr_ptr = w^.ptr
                }
                
                mut inner_ty = alloc LLVMType()
                inner_ty^ = LLVMType.I64
                when llvm_value_get_type(arr_ptr)^ {
                    Pointer(inner) -> { inner_ty = inner }
                    I1 -> {} I8 -> {} I32 -> {} I64 -> {} Double -> {} Void -> {} Array(sz, in_ty) -> {} Named(n) -> {}
                }
                
                mut idx_vals = new_list(1, arr_ptr)
                mut idx_const = alloc LLVMValue()
                idx_const^ = LLVMValue.ConstI64(0)
                list_push(idx_vals, idx_const^)
                let element_ptr = ir_builder_build_gep(gen^.builder, inner_ty, arr_ptr, idx_vals)
                
                mut field_ty = alloc TypeInfo()
                field_ty^ = TypeInfo.Int
                mut f_ty_opt: ?TypeInfoPtr = hashmap_get(gen^.type_env, field_key)
                if f_ty_opt == None {
                    f_ty_opt = hashmap_get(gen^.type_env, raw_name)
                }
                if f_ty_opt != None {
                    let f_tw: TypeInfoPtr = f_ty_opt
                    mut f_tw_alloc = alloc TypeInfoPtr()
                    f_tw_alloc^ = f_tw
                    field_ty = f_tw_alloc^.ptr
                }
                let target_llvm_ty = llvm_generator_type_to_llvm(gen, field_ty)
                mut ptarget_ty = alloc LLVMType()
                ptarget_ty^ = LLVMType.Pointer(target_llvm_ty)
                let casted_ptr = ir_builder_build_bitcast(gen^.builder, element_ptr, ptarget_ty)
                
                loaded = ir_builder_build_load(gen^.builder, casted_ptr, 8)
            }
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = loaded
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(i) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
            }
        }
        StoreProperty(obj, prop, val) -> {
            mut raw_name = ""
            when obj^ {
                Variable(n) -> { raw_name = n }
                LiteralInt(i) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} TempReg(t) -> {} Void -> {} NoneLiteral -> {}
            }
            let field_key = concat_strings(raw_name, concat_strings("_", prop))
            
            let is_soa = hashmap_get(gen^.function_params, field_key) != None
            mut is_custom_struct = false
            mut struct_name = ""
            
            if not is_soa {
                mut ty_opt: ?TypeInfoPtr = hashmap_get(gen^.type_env, raw_name)
                if ty_opt != None {
                    let tw_val: TypeInfoPtr = ty_opt
                    mut tw = alloc TypeInfoPtr()
                    tw^ = tw_val
                    let var_ty = tw^.ptr
                    let s_name_opt = llvm_generator_get_struct_name(gen, var_ty)
                    if s_name_opt != None {
                        let s_name: String = s_name_opt
                        if llvm_generator_is_custom_struct(gen, s_name) {
                            is_custom_struct = true
                            struct_name = s_name
                        }
                    }
                }
            }
            
            let val_val = llvm_generator_operand_to_value(gen, val)
            
            if is_custom_struct {
                let heap_ptr = llvm_generator_operand_to_value(gen, obj)
                
                mut i64_inner = alloc LLVMType()
                i64_inner^ = LLVMType.I64
                mut pi64_ty = alloc LLVMType()
                pi64_ty^ = LLVMType.Pointer(i64_inner)
                let casted_i64_ptr = ir_builder_build_bitcast(gen^.builder, heap_ptr, pi64_ty)
                
                let index = llvm_generator_get_field_index(gen, struct_name, prop)
                mut idx_vals = new_list(1, heap_ptr)
                mut idx_const = alloc LLVMValue()
                idx_const^ = LLVMValue.ConstI64(index)
                list_push(idx_vals, idx_const^)
                let element_ptr = ir_builder_build_gep(gen^.builder, i64_inner, casted_i64_ptr, idx_vals)
                
                let val_ty = llvm_value_get_type(val_val)
                mut pval_ty = alloc LLVMType()
                pval_ty^ = LLVMType.Pointer(val_ty)
                let target_ptr = ir_builder_build_bitcast(gen^.builder, element_ptr, pval_ty)
                
                ir_builder_build_store(gen^.builder, val_val, target_ptr, 8)
            } else {
                mut arr_ptr = alloc LLVMValue()
                mut ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, field_key)
                if ptr_opt == None {
                    ptr_opt = hashmap_get(gen^.function_params, raw_name)
                }
                if ptr_opt != None {
                    let w_val: LLVMValuePtr = ptr_opt
                    mut w = alloc LLVMValuePtr()
                    w^ = w_val
                    arr_ptr = w^.ptr
                }
                
                mut inner_ty = alloc LLVMType()
                inner_ty^ = LLVMType.I64
                when llvm_value_get_type(arr_ptr)^ {
                    Pointer(inner) -> { inner_ty = inner }
                    I1 -> {} I8 -> {} I32 -> {} I64 -> {} Double -> {} Void -> {} Array(sz, in_ty) -> {} Named(n) -> {}
                }
                
                mut idx_vals = new_list(1, arr_ptr)
                mut idx_const = alloc LLVMValue()
                idx_const^ = LLVMValue.ConstI64(0)
                list_push(idx_vals, idx_const^)
                let element_ptr = ir_builder_build_gep(gen^.builder, inner_ty, arr_ptr, idx_vals)
                
                mut field_ty = alloc TypeInfo()
                field_ty^ = TypeInfo.Int
                mut f_ty_opt: ?TypeInfoPtr = hashmap_get(gen^.type_env, field_key)
                if f_ty_opt == None {
                    f_ty_opt = hashmap_get(gen^.type_env, raw_name)
                }
                if f_ty_opt != None {
                    let f_tw: TypeInfoPtr = f_ty_opt
                    mut f_tw_alloc = alloc TypeInfoPtr()
                    f_tw_alloc^ = f_tw
                    field_ty = f_tw_alloc^.ptr
                }
                let target_llvm_ty = llvm_generator_type_to_llvm(gen, field_ty)
                mut ptarget_ty = alloc LLVMType()
                ptarget_ty^ = LLVMType.Pointer(target_llvm_ty)
                let casted_ptr = ir_builder_build_bitcast(gen^.builder, element_ptr, ptarget_ty)
                
                ir_builder_build_store(gen^.builder, val_val, casted_ptr, 8)
            }
        }
        Call(dest_opt, callee, args) -> {
            puts("DEBUG LOWER: entered Call arm")
            mut callee_str = ""
            when callee^ {
                Variable(n) -> { callee_str = n }
                LiteralInt(i) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} TempReg(t) -> {} Void -> {} NoneLiteral -> {}
            }
            callee_str = string_replace(callee_str, "(", "_")
            callee_str = string_replace(callee_str, ")", "")
            callee_str = string_replace(callee_str, ", ", "_")
            callee_str = string_replace(callee_str, "^", "Ptr")
            
            mut dummy_val = alloc LLVMValue()
            mut arg_vals = new_list(10, dummy_val)
            mut i = 0
            while i < args^.length {
                let a_ptr = list_get(args, i)
                mut a = alloc IROperand()
                a^ = a_ptr
                let a_val = llvm_generator_operand_to_value(gen, a)
                list_push(arg_vals, a_val^)
                i = i + 1
            }
            
            mut ret_ty = alloc LLVMType()
            ret_ty^ = LLVMType.I64
            if dest_opt == None { ret_ty^ = LLVMType.Void }
            
            let res = ir_builder_build_call(gen^.builder, ret_ty, callee_str, arg_vals)
            
            if dest_opt != None {
                let d: ^IROperand = dest_opt
                when d^ {
                    TempReg(t) -> {
                        mut vw = alloc LLVMValuePtr()
                        vw^.ptr = res
                        hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                    }
                    LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
                }
            }
        }
        ExtractTag(dest, target_struct) -> {
            let target_val = llvm_generator_operand_to_value(gen, target_struct)
            
            mut idx_val = alloc LLVMValue()
            idx_val^ = LLVMValue.ConstI64(0)
            mut dummy_lv = alloc LLVMValue()
            mut idx_list = new_list(1, dummy_lv)
            list_push(idx_list, idx_val^)
            
            mut i64_ty = alloc LLVMType()
            i64_ty^ = LLVMType.I64
            mut pi64_ty = alloc LLVMType()
            pi64_ty^ = LLVMType.Pointer(i64_ty)
            
            let casted_target = ir_builder_build_bitcast(gen^.builder, target_val, pi64_ty)
            let ptr = ir_builder_build_gep(gen^.builder, i64_ty, casted_target, idx_list)
            let tag_val = ir_builder_build_load(gen^.builder, ptr, 8)
            
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = tag_val
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                Variable(name) -> {
                    mut ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, name)
                    if ptr_opt != None {
                        let ptr_wrap_val: LLVMValuePtr = ptr_opt
                        mut ptr_wrap = alloc LLVMValuePtr()
                        ptr_wrap^ = ptr_wrap_val
                        ir_builder_build_store(gen^.builder, tag_val, ptr_wrap^.ptr, 0)
                    } else {
                        mut vw = alloc LLVMValuePtr()
                        vw^.ptr = tag_val
                        hashmap_put(gen^.function_params, name, vw^)
                    }
                }
                LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Void -> {} NoneLiteral -> {}
            }
        }
        Alloc(dest, ty_name, size) -> {
            mut size_val = alloc LLVMValue()
            size_val^ = LLVMValue.ConstI64(size)
            mut dummy_lv = alloc LLVMValue()
            mut arg_list = new_list(1, dummy_lv)
            list_push(arg_list, size_val^)
            
            mut i8_ptr = alloc LLVMType()
            mut i8_inner = alloc LLVMType()
            i8_inner^ = LLVMType.I8
            i8_ptr^ = LLVMType.Pointer(i8_inner)
            
            let alloc_call = ir_builder_build_call(gen^.builder, i8_ptr, "malloc", arg_list)
            
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = alloc_call
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Variable(name) -> {} Void -> {} NoneLiteral -> {}
            }
        }
        Free(target) -> {
            let ptr_val = llvm_generator_operand_to_value(gen, target)
            mut i8_ptr = alloc LLVMType()
            mut i8_inner = alloc LLVMType()
            i8_inner^ = LLVMType.I8
            i8_ptr^ = LLVMType.Pointer(i8_inner)
            let void_ptr = ir_builder_build_bitcast(gen^.builder, ptr_val, i8_ptr)
            
            mut dummy_lv = alloc LLVMValue()
            mut arg_list = new_list(1, dummy_lv)
            list_push(arg_list, void_ptr^)
            mut vty = alloc LLVMType()
            vty^ = LLVMType.Void
            let ignore = ir_builder_build_call(gen^.builder, vty, "free", arg_list)
        }
        ExtractPayload(dest, target_struct, field_idx) -> {
            let target_val = llvm_generator_operand_to_value(gen, target_struct)
            
            let offset = field_idx + 1
            
            mut idx_val = alloc LLVMValue()
            idx_val^ = LLVMValue.ConstI64(offset)
            mut dummy_lv = alloc LLVMValue()
            mut idx_list = new_list(1, dummy_lv)
            list_push(idx_list, idx_val^)
            
            mut target_llvm_ty = alloc LLVMType()
            target_llvm_ty^ = LLVMType.I64
            
            when dest^ {
                Variable(name) -> {
                    mut ty_opt: ?TypeInfoPtr = hashmap_get(gen^.type_env, name)
                    if ty_opt != None {
                        let tw_val: TypeInfoPtr = ty_opt
                        mut tw = alloc TypeInfoPtr()
                        tw^ = tw_val
                        target_llvm_ty = llvm_generator_type_to_llvm(gen, tw^.ptr)
                    }
                }
                TempReg(t) -> {} LiteralInt(ii) -> {} LiteralFloat(f) -> {} LiteralString(s) -> {} LiteralChar(c) -> {} LiteralBool(b) -> {} Void -> {} NoneLiteral -> {}
            }
            
            mut i64_ty = alloc LLVMType()
            i64_ty^ = LLVMType.I64
            mut pi64_ty = alloc LLVMType()
            pi64_ty^ = LLVMType.Pointer(i64_ty)
            
            let casted_target = ir_builder_build_bitcast(gen^.builder, target_val, pi64_ty)
            let ptr = ir_builder_build_gep(gen^.builder, i64_ty, casted_target, idx_list)
            
            mut ptarget_ty = alloc LLVMType()
            ptarget_ty^ = LLVMType.Pointer(target_llvm_ty)
            
            let casted_ptr = ir_builder_build_bitcast(gen^.builder, ptr, ptarget_ty)
            let loaded_val = ir_builder_build_load(gen^.builder, casted_ptr, 8)
            
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = loaded_val
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
                }
                Variable(name) -> {
                    mut ptr_opt: ?LLVMValuePtr = hashmap_get(gen^.function_params, name)
                    if ptr_opt != None {
                        let ptr_wrap_val: LLVMValuePtr = ptr_opt
                        mut ptr_wrap = alloc LLVMValuePtr()
                        ptr_wrap^ = ptr_wrap_val
                        
                        let dest_ptr_ty = llvm_value_get_type(ptr_wrap^.ptr)
                        let payload_val_ty = llvm_value_get_type(loaded_val)
                        mut p_payload_val_ty = alloc LLVMType()
                        p_payload_val_ty^ = LLVMType.Pointer(payload_val_ty)
                        let target_ptr = ir_builder_build_bitcast(gen^.builder, ptr_wrap^.ptr, p_payload_val_ty)
                        
                        ir_builder_build_store(gen^.builder, loaded_val, target_ptr, 0)
                    } else {
