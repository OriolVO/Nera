            let base_ptr = ir_builder_build_load(gen^.builder, arr_ptr, 8)
            
            mut byte_idx = idx_val
            mut eight = alloc LLVMValue()
            eight^ = LLVMValue.ConstI64(8)
            byte_idx = ir_builder_build_mul(gen^.builder, idx_val, eight)
            
            mut dummy_lv = alloc LLVMValue()
            mut idx_list = new_list(1, dummy_lv)
