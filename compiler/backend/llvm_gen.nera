        Substring(dest, str_ptr, start_op, end_op) -> {
            let str_val = llvm_generator_operand_to_value(gen, str_ptr)
            let s_val = llvm_generator_operand_to_value(gen, start_op)
            let e_val = llvm_generator_operand_to_value(gen, end_op)
            
            mut dummy_lv = alloc LLVMValue()
            mut args = new_list(3, dummy_lv)
            list_push(args, str_val^)
            list_push(args, s_val^)
            list_push(args, e_val^)
            
            mut i8_inner = alloc LLVMType()
            i8_inner^ = LLVMType.I8
            mut pi8_ty = alloc LLVMType()
            pi8_ty^ = LLVMType.Pointer(i8_inner)
            
            let sub_str = ir_builder_build_call(gen^.builder, pi8_ty, "string_substring", args)
            
            when dest^ {
                TempReg(t) -> {
                    mut vw = alloc LLVMValuePtr()
                    vw^.ptr = sub_str
                    hashmap_put(gen^.temp_map, int_to_string(t), vw^)
