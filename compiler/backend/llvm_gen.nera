        ConstructADT(dest, tag_value, args) -> {
            let total_size = 8 + (args^.length * 8)
            
            mut size_val = alloc LLVMValue()
            size_val^ = LLVMValue.ConstI64(total_size)
            mut dummy_lv = alloc LLVMValue()
            mut malloc_args = new_list(1, dummy_lv)
            list_push(malloc_args, size_val^)
            
            mut i8_inner = alloc LLVMType()
            i8_inner^ = LLVMType.I8
            mut pi8_ty = alloc LLVMType()
            pi8_ty^ = LLVMType.Pointer(i8_inner)
            
            let struct_ptr = ir_builder_build_call(gen^.builder, pi8_ty, "malloc", malloc_args)
            
            mut tag_val = alloc LLVMValue()
            tag_val^ = LLVMValue.ConstI64(tag_value)
            
