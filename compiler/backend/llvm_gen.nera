            mut pi64_ty = alloc LLVMType()
            pi64_ty^ = LLVMType.Pointer(i64_ty)
            
            let casted_i64_ptr = ir_builder_build_bitcast(gen^.builder, ptr_val, pi64_ty)
            let element_ptr = ir_builder_build_gep(gen^.builder, i64_ty, casted_i64_ptr, idx_list)
            
