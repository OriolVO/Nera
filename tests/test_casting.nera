// test_casting.nera
use std.io

fn main() {
    let f = 3.14
    let i = f as Int
    
    if i == 3 {
        print(1)
    } else {
        print(0)
    }

    let c = '7'
    let val = (c as Int) - ('0' as Int)

    if val == 7 {
        print(1)
    } else {
        print(0)
    }

    let b = true
    let b_int = b as Int

    if b_int == 1 {
        print(1)
    } else {
        print(0)
    }

    let i_val = 5
    let is_active = i_val as Boolean

    if is_active {
        print(1)
    } else {
        print(0)
    }
}
