// test_break_continue.nera
use std.io

fn test_break() {
    mut i = 0
    mut sum = 0
    while i < 10 {
        if i == 5 {
            break
        }
        sum = sum + i
        i = i + 1
    }
    // 0 + 1 + 2 + 3 + 4 = 10
    if sum == 10 { print(1) } else { print(0) }
}

fn test_continue() {
    mut i = 0
    mut sum = 0
    while i < 5 {
        i = i + 1
        if i == 3 {
            continue
        }
        sum = sum + i
    }
    // 1 + 2 + 4 + 5 = 12
    if sum == 12 { print(1) } else { print(0) }
}

fn test_scoping() {
    mut outer_var = 10
    mut i = 0
    while i < 3 {
        let inner_var = 5
        outer_var = outer_var + inner_var
        i = i + 1
    }
    // 10 + 5 + 5 + 5 = 25
    if outer_var == 25 { print(1) } else { print(0) }
}

fn main() {
    test_break()
    test_continue()
    test_scoping()
}
